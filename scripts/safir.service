[Unit]
Description=SAFIR Feldgeraet (Jetson Orin Nano) - Whisper + Ollama + FastAPI
Documentation=file:///home/jetson/cgi-afcea-san/CLAUDE.md
After=network-online.target tailscaled.service
Wants=network-online.target

[Service]
Type=simple
User=root
WorkingDirectory=/home/jetson/cgi-afcea-san
ExecStart=/home/jetson/cgi-afcea-san/scripts/safir-start.sh
Restart=on-failure
RestartSec=5
StartLimitBurst=5
StartLimitIntervalSec=60
KillMode=control-group
TimeoutStopSec=20
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
