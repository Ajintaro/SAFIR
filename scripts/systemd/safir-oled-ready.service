[Unit]
Description=SAFIR OLED SSH-Status-Monitor (BEREIT/AKTIV + Netzwerk-Info)
Wants=network-online.target
After=network-online.target tailscaled.service

[Service]
Type=simple
ExecStart=/usr/bin/python3 /home/jetson/cgi-afcea-san/scripts/oled-status.py ssh-watch
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
